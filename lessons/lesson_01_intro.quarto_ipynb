        "\n",
        "# Направления и страны\n",
        "print(\"Направления:\", df['NAPR'].unique())\n",
        "print(\"Страны (топ-10):\", df['STRANA'].value_counts().head(10))\n",
        "print(\"Период:\", df['PERIOD'].min(), \"—\", df['PERIOD'].max())"
